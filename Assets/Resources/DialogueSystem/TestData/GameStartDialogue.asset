  m_Script: {fileID: 11500000, guid: 27f8749596482864282d738d4e870adc, type: 3}
  m_Name: GameStartDialogue
  m_EditorClassIdentifier: 
  portraitLeft: {fileID: 169958680, guid: 41e195343081662448ef5b41dfddba04, type: 3}
  portraitRight: {fileID: -1639218750, guid: 34c23408b93394846a0eceb58c4c806e, type: 3}
  nameLeft: Role
  nameRight: Robot
  lines:
  - speaker: 0
    text: "\u8FD9\u662F\u8FDB\u5165\u4E86\u4E2A\u4EC0\u4E48\u5730\u65B9"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 1
    text: "\u5927\u6982\u662F\u6587\u4EF6\u534F\u8BAE\u540E\u81EA\u5E26\u7684\u7CFB\u7EDF\uFF0C\u4F60\u5E94\u8BE5\u76F4\u63A5\u88AB\u62C9\u8FDB\u6765\u4E86"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 1
    text: "\u8FD9\u4E0A\u9762\u8BF4\u662F\u201C\u8FD9\u662F\u4EFB\u52A1\u7684\u4E00\u90E8\u5206\u201C\u5148\u4E60\u60EF\u4E00\u4E0B\u8FD9\u4E2A\u6A21\u62DF\u7CFB\u7EDF"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 0
    text: "\xB7\xB7\xB7\xB7\xB7\xB7"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 0
    text: "\u4F60\u518D\u89E3\u91CA\u4E00\u4E0B\u8FD9\u662F\u4E2A\u4EC0\u4E48\u7CFB\u7EDF"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 1
    text: "\u5927\u6982\u662F\u9003\u79BB\u6A21\u62DF\u8FD9\u79CD\u611F\u89C9\u7684\u4E1C\u897F\uFF0C\u4F60\u53EF\u4EE5\u5148\u8BD5\u8BD5\uFF0C\u6211\u5148\u5F00\u542F\u4E00\u4E2A\u6700\u7B80\u5355\u7684\u6A21\u5F0F"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 0
    text: "\xB7\xB7\xB7\xB7\xB7\xB7"
    lineBeginEventId: 
    lineCompleteEventId: 
  - speaker: 1
    text: "\u63A5\u4E0B\u6765\u9760\u4F60\u4E86\uFF0C\u5148\u8BD5\u8BD5\u8DF3\u7740\u8EB2\u907F\u5427"
    lineBeginEventId: 
    lineCompleteEventId: 
  dialogueStartEventId: 
  dialogueEndEventId: Game_Start
  typingSoundOverride: {fileID: 0}
